  } else {
    # Plain text log (errors, etc)
    .log_type = "plain"
    .parser_used = "extend_json_g2"
  }
  
  # Common metadata cleanup
  .service = .container_name
  
  del(.label)
  del(.container_id)
  del(.image)
  del(.source_type)
  del(.stream)
  del(.log_format_type)
  
