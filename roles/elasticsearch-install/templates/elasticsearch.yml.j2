# ======================== Elasticsearch Configuration =========================
# Generated by Ansible. Do not edit manually.

# ---------------------------------- Cluster -----------------------------------
cluster.name: {{ es_cluster_name }}

# ------------------------------------ Node ------------------------------------
node.name: {{ es_node_name }}

# ----------------------------------- Paths ------------------------------------
path.data: /usr/share/elasticsearch/data
path.logs: /usr/share/elasticsearch/logs

# ---------------------------------- Network -----------------------------------
network.host: {{ es_network_host }}
http.port: {{ es_http_port }}
transport.tcp.port: {{ es_transport_port }}

# --------------------------------- Discovery ----------------------------------
{% if es_discovery_hosts | length > 0 %}
discovery.zen.ping.unicast.hosts: {{ es_discovery_hosts | to_json }}
{% else %}
discovery.zen.ping.unicast.hosts: []
{% endif %}
discovery.zen.minimum_master_nodes: {{ es_minimum_master_nodes }}

# ---------------------------------- X-Pack -----------------------------------
xpack.security.enabled: {{ es_xpack_security_enabled | lower }}
xpack.monitoring.collection.enabled: {{ es_xpack_monitoring_enabled | lower }}
