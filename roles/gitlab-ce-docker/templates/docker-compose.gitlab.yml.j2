services:
  gitlab:
    image: {{gitlab_registry}}:{{gitlab_image}}
    container_name: gitlab
    hostname: gitlab-{{stand_type}}
{% if gitlab_network_mode_host is defined and gitlab_network_mode_host %}
    network_mode: host
{% endif %}
    environment:
      GITLAB_OMNIBUS_CONFIG: |
{% for e in gitlab_settings %}
        {{ e }}
{% endfor %}
{% if gitlab_disable_internal_nginx is defined and gitlab_disable_internal_nginx %}
{% for e in gitlab_workhorse_settings %}
        {{ e }}
{% endfor %}
{% endif %}
    volumes:
      - {{gitlab_data_path}}/conf:/etc/gitlab
      - {{gitlab_data_path}}/logs:/var/log/gitlab
      - {{gitlab_data_path}}/data:/var/opt/gitlab
      - {{gitlab_backup_path}}:/var/opt/gitlab/backups # ovveride backup folder
{% if gitlab_support_ssl is defined %}
      - {{gitlab_ssl_path}}:/opt/ssl
{% endif %}
{% if not (gitlab_network_mode_host is defined and gitlab_network_mode_host) %}
{% if gitlab_disable_internal_nginx is defined and gitlab_disable_internal_nginx %}
    # External NGINX mode - expose Workhorse, Registry, and Pages
    ports:
{% if gitlab_https_expose_addr is defined %}
      - "{{ gitlab_https_expose_addr }}:{{ gitlab_workhorse_port }}:{{ gitlab_workhorse_port }}"
{% else %}
      - "{{ gitlab_workhorse_port }}:{{ gitlab_workhorse_port }}"
{% endif %}
      - "{{ gitlab_ssh_port }}:22"
{% if gitlab_https_expose_addr is defined %}
      - "{{ gitlab_https_expose_addr }}:5000:5000"
      - "{{ gitlab_https_expose_addr }}:8090:8090"
{% else %}
      - "5000:5000"
      - "8090:8090"
{% endif %}
{% else %}
    # Internal NGINX mode - expose NGINX ports
{% if gitlab_https_expose_addr is defined %}
    ports:
      - "{{ gitlab_https_expose_addr }}:80:80"
      - "{{ gitlab_https_expose_addr }}:443:443"
      - "{{ gitlab_ssh_port }}:22"
{% else %}
    ports:
      - "80:80"
      - "443:443"
      - "{{ gitlab_ssh_port }}:22"
{% endif %}
{% endif %}
{% endif %}
    shm_size: '256m'
    restart: {{ gitlab_restart | default('always') }}
    logging:
      driver: json-file
      options:
        max-size: 100m
        max-file: '2'
