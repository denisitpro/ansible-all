{% for k, v in k8s_grafana_annotations.items() %}
{% if '\n' in v %}
      {{ k }}: |
{% for line in v.splitlines() %}
        {{ line }}
{% endfor %}
{% else %}
      {{ k }}: "{{ v }}"
{% endif %}
{% endfor %}
{% endif %}
{% if k8s_grafana_labels is defined %}
    labels:
{% for k, v in k8s_grafana_labels.items() %}
      {{ k }}: "{{ v }}"
{% endfor %}
{% endif %}
{% endif %}

