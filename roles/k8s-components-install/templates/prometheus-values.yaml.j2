additionalServiceMonitors:
{% for monitor in k8s_prom_additional_service_monitors %}
  - name: {{ monitor.name }}
    selector:
      matchLabels:
        {{ monitor.selector.matchLabels | to_nice_yaml(indent=2) | indent(8, False) }}
    namespaceSelector:
      {{ monitor.namespaceSelector | to_nice_yaml(indent=2) | indent(6, False) }}
    endpoints:
{% for endpoint in monitor.endpoints %}
      - port: {{ endpoint.port }}
        interval: {{ endpoint.interval | default("30s") }}
{% if endpoint.path is defined %}
        path: {{ endpoint.path }}
{% endif %}
{% if endpoint.metric_relabel_configs is defined and endpoint.metric_relabel_configs | length > 0 %}
        metricRelabelings:
{% for relabel in endpoint.metric_relabel_configs %}
          - {{ relabel | to_nice_yaml(indent=2) | indent(12, False) }}
{% endfor %}
{% endif %}
{% endfor %}
{% endfor %}
{% endif %}
