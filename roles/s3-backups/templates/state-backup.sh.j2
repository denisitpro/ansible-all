#!/usr/bin/env bash
# AWS S3 State Backup script
# Generated by Ansible - DO NOT EDIT MANUALLY
# Managed by s3-backups role
#
# Process: AWS S3 -> Download -> Encrypt (backup-directory.sh) -> Upload (backup-upload.sh) -> Cleanup

set -euo pipefail

# Script configuration
SCRIPT_NAME="state-backup"
LOG_DIR="{{ state_backup_log_dir }}"
LOG_FILE="${LOG_DIR}/state-backup-$(date +%Y%m%d-%H%M%S).log"
LOCK_FILE="/tmp/${SCRIPT_NAME}.lock"

# Directories
DOWNLOAD_DIR="{{ state_backup_download_dir | default('/mnt/s3-state-backup') }}"
ENCRYPT_DIR="{{ backup_dest_dir | default('/mnt/s3-state-encrypt') }}"

# Scripts from backup-directory role
BACKUP_SCRIPT="/opt/scripts/backup-directory.sh"
BACKUP_UPLOAD_SCRIPT="/opt/scripts/backup-upload.sh"

# Rclone configuration
SOURCE_REMOTE="{{ state_backup_config.source_remote }}"
DEST_REMOTE="{{ state_backup_config.destination.remote }}"
DEST_BUCKET="{{ state_backup_config.destination.bucket }}"
DEST_PATH="{{ state_backup_config.destination.path }}"

# Ensure directories exist
mkdir -p "${LOG_DIR}"
mkdir -p "${DOWNLOAD_DIR}"
mkdir -p "${ENCRYPT_DIR}"

# Function to log messages
log() {
    echo "[$(date +'%Y-%m-%d %H:%M:%S')] $*" | tee -a "${LOG_FILE}"
}

# Function to cleanup on exit
cleanup() {
    if [ -f "${LOCK_FILE}" ]; then
        rm -f "${LOCK_FILE}"
    fi
}

trap cleanup EXIT

# Check if backup scripts exist
if [ ! -f "${BACKUP_SCRIPT}" ]; then
    log "ERROR: Backup script not found: ${BACKUP_SCRIPT}"
    exit 1
fi

if [ ! -f "${BACKUP_UPLOAD_SCRIPT}" ]; then
    log "ERROR: Upload script not found: ${BACKUP_UPLOAD_SCRIPT}"
    exit 1
fi

# Check if another instance is running
if [ -f "${LOCK_FILE}" ]; then
    log "ERROR: Another instance is already running (lock file exists: ${LOCK_FILE})"
    exit 1
fi

# Create lock file
touch "${LOCK_FILE}"

log "=== Starting AWS S3 state backup ==="

{% if state_backup_config.buckets | length == 0 %}
log "ERROR: No buckets configured for backup"
exit 1
{% endif %}

# Counters
ERRORS=0
DOWNLOAD_SUCCESS=0
ENCRYPT_SUCCESS=0
TOTAL_BUCKETS={{ state_backup_config.buckets | length }}

{% for bucket in state_backup_config.buckets %}
log "--- Processing bucket {{ loop.index }}/{{ state_backup_config.buckets | length }}: {{ bucket }} ---"

BUCKET_NAME="{{ bucket }}"
BUCKET_DOWNLOAD_PATH="${DOWNLOAD_DIR}/${BUCKET_NAME}"
BUCKET_ENCRYPT_PATH="${ENCRYPT_DIR}/${BUCKET_NAME}"

# Step 1: Download from AWS S3
log "Step 1/2: Downloading ${BUCKET_NAME} from AWS S3"
rm -rf "${BUCKET_DOWNLOAD_PATH}"
mkdir -p "${BUCKET_DOWNLOAD_PATH}"

if rclone sync \
  "${SOURCE_REMOTE}:${BUCKET_NAME}" \
  "${BUCKET_DOWNLOAD_PATH}" \
  --transfers {{ state_backup_rclone_options.transfers }} \
  --checkers {{ state_backup_rclone_options.checkers }} \
  --retries {{ state_backup_rclone_options.retries }} \
  --log-file "${LOG_FILE}" \
  --log-level INFO{% if state_backup_dry_run | default(false) %} \
  --dry-run{% endif %}; then
    log "SUCCESS: Downloaded ${BUCKET_NAME}"
    DOWNLOAD_SIZE=$(du -sh "${BUCKET_DOWNLOAD_PATH}" 2>/dev/null | cut -f1 || echo "N/A")
    log "Download size: ${DOWNLOAD_SIZE}"
    DOWNLOAD_SUCCESS=$((DOWNLOAD_SUCCESS + 1))
    
{% if not state_backup_dry_run | default(false) %}
    # Step 2: Encrypt using backup-directory.sh
    log "Step 2/2: Encrypting ${BUCKET_NAME} using backup-directory.sh"
    mkdir -p "${BUCKET_ENCRYPT_PATH}"
    
    if bash "${BACKUP_SCRIPT}" \
      --source "${BUCKET_DOWNLOAD_PATH}" \
      --dest "${BUCKET_ENCRYPT_PATH}" \
      --prefix "${BUCKET_NAME}" \
      --log-file "${LOG_FILE}"; then
        log "SUCCESS: Encrypted ${BUCKET_NAME}"
        
        # Find and log the encrypted archive
        ENCRYPTED_ARCHIVE=$(find "${BUCKET_ENCRYPT_PATH}" -name "${BUCKET_NAME}_*.tar.gz.age" -type f -printf '%T@ %p\n' | sort -rn | head -1 | cut -d' ' -f2-)
        if [ -n "${ENCRYPTED_ARCHIVE}" ]; then
            ENCRYPTED_SIZE=$(du -h "${ENCRYPTED_ARCHIVE}" | cut -f1)
            log "Encrypted archive: ${ENCRYPTED_ARCHIVE} (${ENCRYPTED_SIZE})"
        fi
        
        ENCRYPT_SUCCESS=$((ENCRYPT_SUCCESS + 1))
    else
        log "ERROR: Failed to encrypt ${BUCKET_NAME}"
        ERRORS=$((ERRORS + 1))
    fi
    
    # Cleanup downloaded files
    log "Cleaning up download: ${BUCKET_DOWNLOAD_PATH}"
    rm -rf "${BUCKET_DOWNLOAD_PATH}"
{% else %}
    log "DRY-RUN: Skipping encryption step"
    rm -rf "${BUCKET_DOWNLOAD_PATH}"
{% endif %}
else
    log "ERROR: Failed to download ${BUCKET_NAME}"
    ERRORS=$((ERRORS + 1))
fi

log "Completed processing ${BUCKET_NAME}"
log ""

{% endfor %}

{% if not state_backup_dry_run | default(false) %}
# Step 3: Upload all encrypted backups to Wasabi using backup-upload.sh
log "=== Step 3: Uploading all encrypted backups to Wasabi ==="

if bash "${BACKUP_UPLOAD_SCRIPT}" \
  --target "${DEST_REMOTE}:${DEST_BUCKET}/${DEST_PATH}/" \
  --local-dir "${ENCRYPT_DIR}" \
  --mode copy \
  --checkers {{ state_backup_rclone_options.checkers }} \
  --transfers {{ state_backup_rclone_options.transfers }}; then
    log "SUCCESS: All encrypted backups uploaded to Wasabi"
else
    log "ERROR: Failed to upload backups to Wasabi"
    ERRORS=$((ERRORS + 1))
fi

# Cleanup local temporary files
log "=== Cleaning up local temporary files ==="
rm -rf "${DOWNLOAD_DIR}"
log "Cleaned up download directory: ${DOWNLOAD_DIR}"

rm -rf "${ENCRYPT_DIR}"
log "Cleaned up encrypted archives directory: ${ENCRYPT_DIR}"

{% endif %}

log "=== State backup completed ==="
log "Total buckets: ${TOTAL_BUCKETS}"
log "Downloaded successfully: ${DOWNLOAD_SUCCESS}"
log "Encrypted successfully: ${ENCRYPT_SUCCESS}"
log "Errors: ${ERRORS}"

if [ ${ERRORS} -gt 0 ]; then
    exit 1
fi

exit 0

