#!/usr/bin/env bash
# Monthly backup script (to AWS Glacier Deep Archive)
# Generated by Ansible - DO NOT EDIT MANUALLY
# Managed by s3-backups role

set -euo pipefail

# Script configuration
SCRIPT_NAME="monthly-backup"
LOG_DIR="{{ monthly_backup_log_dir }}"
LOG_FILE="${LOG_DIR}/monthly-backup-$(date +%Y%m%d-%H%M%S).log"
LOCK_FILE="/tmp/${SCRIPT_NAME}.lock"

# Ensure log directory exists
mkdir -p "${LOG_DIR}"

# Function to log messages
log() {
    echo "[$(date +'%Y-%m-%d %H:%M:%S')] $*" | tee -a "${LOG_FILE}"
}

# Function to cleanup on exit
cleanup() {
    if [ -f "${LOCK_FILE}" ]; then
        rm -f "${LOCK_FILE}"
    fi
}

trap cleanup EXIT

# Check if another instance is running
if [ -f "${LOCK_FILE}" ]; then
    log "ERROR: Another instance is already running (lock file exists: ${LOCK_FILE})"
    exit 1
fi

# Create lock file
touch "${LOCK_FILE}"

log "=== Starting monthly backup to AWS Glacier Deep Archive ==="

{% if monthly_backup_config.sources | length == 0 %}
log "ERROR: No sources configured"
exit 1
{% endif %}

{% if monthly_backup_config.destinations | length == 0 %}
log "ERROR: No destinations configured"
exit 1
{% endif %}

# Backup execution
ERRORS=0

{% for destination in monthly_backup_config.destinations %}
log "--- Processing destination: {{ destination.remote }}:{{ destination.bucket }} ---"

{% for source in monthly_backup_config.sources %}
log "Copying from {{ source.remote }}:{{ source.bucket }}"

{% if destination.subdir_by_source | default(true) %}
DEST_PATH="{{ destination.remote }}:{{ destination.bucket }}/{{ source.bucket }}"
{% else %}
DEST_PATH="{{ destination.remote }}:{{ destination.bucket }}"
{% endif %}

if rclone copy \
  "{{ source.remote }}:{{ source.bucket }}" \
  "${DEST_PATH}" \
  --max-age "{{ monthly_backup_options.max_age }}" \
{% if monthly_backup_options.ignore_existing | default(true) %}
  --ignore-existing \
{% endif %}
  --transfers {{ monthly_backup_options.transfers }} \
  --checkers {{ monthly_backup_options.checkers }} \
{% if monthly_backup_options.buffer_size | default('') != '' %}
  --buffer-size "{{ monthly_backup_options.buffer_size }}" \
{% endif %}
  --retries {{ monthly_backup_options.retries | default(3) }} \
{% if monthly_backup_options.fast_list | default(true) %}
  --fast-list \
{% endif %}
{% if monthly_backup_options.use_server_modtime | default(false) %}
  --use-server-modtime \
{% endif %}
{% if monthly_backup_options.checksum | default(false) %}
  --checksum \
{% endif %}
{% if monthly_backup_options.bwlimit | default('') != '' %}
  --bwlimit "{{ monthly_backup_options.bwlimit }}" \
{% endif %}
{% if monthly_backup_options.s3_chunk_size | default('') != '' %}
  --s3-chunk-size "{{ monthly_backup_options.s3_chunk_size }}" \
{% endif %}
{% if monthly_backup_options.s3_upload_concurrency | default(0) > 0 %}
  --s3-upload-concurrency {{ monthly_backup_options.s3_upload_concurrency }} \
{% endif %}
{% if monthly_backup_options.multi_thread_streams | default(0) > 0 %}
  --multi-thread-streams {{ monthly_backup_options.multi_thread_streams }} \
{% endif %}
{% if monthly_backup_s3_no_check_bucket | default(false) %}
  --s3-no-check-bucket \
{% endif %}
  --log-file "${LOG_FILE}" \
  --log-level {{ monthly_backup_log_level }}{% if monthly_backup_dry_run | default(true) %} \
  --dry-run{% endif %}; then
    log "SUCCESS: {{ source.remote }}:{{ source.bucket }} -> ${DEST_PATH}"
else
    log "ERROR: Failed to copy {{ source.remote }}:{{ source.bucket }} -> ${DEST_PATH}"
    ERRORS=$((ERRORS + 1))
fi

{% endfor %}
{% endfor %}

log "=== Monthly backup completed with ${ERRORS} error(s) ==="

if [ ${ERRORS} -gt 0 ]; then
    exit 1
fi

exit 0

