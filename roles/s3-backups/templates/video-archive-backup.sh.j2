#!/usr/bin/env bash
# Video archive backup script (Dropbox -> Backblaze B2)
# Generated by Ansible - DO NOT EDIT MANUALLY
# Managed by s3-backups role
#
# Optimized for:
# - Large datasets (~10TB of photo/video files)
# - Dropbox API rate limits and constraints
# - Append-only incremental backups
# - 4 cores / 8GB RAM server

set -euo pipefail

# Script configuration
SCRIPT_NAME="video-archive-backup"
LOG_DIR="{{ video_archive_backup_log_dir }}"
LOG_FILE="${LOG_DIR}/video-archive-backup-$(date +%Y%m%d-%H%M%S).log"
LOCK_FILE="/tmp/${SCRIPT_NAME}.lock"

# Ensure log directory exists
mkdir -p "${LOG_DIR}"

# Function to log messages
log() {
    echo "[$(date +'%Y-%m-%d %H:%M:%S')] $*" | tee -a "${LOG_FILE}"
}

# Function to cleanup on exit
cleanup() {
    if [ -f "${LOCK_FILE}" ]; then
        rm -f "${LOCK_FILE}"
    fi
}

trap cleanup EXIT

# Check if another instance is running
if [ -f "${LOCK_FILE}" ]; then
    log "ERROR: Another instance is already running (lock file exists: ${LOCK_FILE})"
    exit 1
fi

# Create lock file
touch "${LOCK_FILE}"

log "=== Starting video archive backup (Dropbox -> B2) ==="
log "Destination: {{ video_archive_backup_config.destination.remote }}:{{ video_archive_backup_config.destination.bucket }}{% if video_archive_backup_config.destination.path %}/{{ video_archive_backup_config.destination.path }}{% endif %}"

{% if video_archive_backup_config.sources | length == 0 %}
log "ERROR: No sources configured"
exit 1
{% endif %}

{% if video_archive_backup_config.destination.remote == "" or video_archive_backup_config.destination.bucket == "" %}
log "ERROR: Destination not configured"
exit 1
{% endif %}

# Backup execution
ERRORS=0
TOTAL_START_TIME=$(date +%s)

{% for source in video_archive_backup_config.sources %}
log "--- Processing source: {{ source.remote }}{% if source.path %}:{{ source.path }}{% endif %} ---"

# Build source path
SOURCE_PATH="{{ source.remote }}:{% if source.path %}{{ source.path }}{% endif %}"

# Build destination path
{% if source.dest_folder | default('') != '' %}
# Use explicit destination folder name
{% if video_archive_backup_config.destination.path %}
DEST_PATH="{{ video_archive_backup_config.destination.remote }}:{{ video_archive_backup_config.destination.bucket }}/{{ video_archive_backup_config.destination.path }}/{{ source.dest_folder }}"
{% else %}
DEST_PATH="{{ video_archive_backup_config.destination.remote }}:{{ video_archive_backup_config.destination.bucket }}/{{ source.dest_folder }}"
{% endif %}
{% else %}
# No destination folder - copy to root
{% if video_archive_backup_config.destination.path %}
DEST_PATH="{{ video_archive_backup_config.destination.remote }}:{{ video_archive_backup_config.destination.bucket }}/{{ video_archive_backup_config.destination.path }}"
{% else %}
DEST_PATH="{{ video_archive_backup_config.destination.remote }}:{{ video_archive_backup_config.destination.bucket }}"
{% endif %}
{% endif %}

log "Source: ${SOURCE_PATH}"
log "Destination: ${DEST_PATH}"
log "Mode: Append-only (ignore existing files)"
{% if video_archive_backup_dry_run | default(true) %}
log "WARNING: Running in DRY-RUN mode (no actual data transfer)"
{% endif %}

# Execute rclone copy with Dropbox-optimized settings
START_TIME=$(date +%s)

if rclone copy \
  "${SOURCE_PATH}" \
  "${DEST_PATH}" \
{% if video_archive_backup_options.tpslimit | default(0) > 0 %}
  --tpslimit {{ video_archive_backup_options.tpslimit }} \
{% endif %}
{% if video_archive_backup_options.tpslimit_burst | default(0) > 0 %}
  --tpslimit-burst {{ video_archive_backup_options.tpslimit_burst }} \
{% endif %}
  --transfers {{ video_archive_backup_options.transfers }} \
  --checkers {{ video_archive_backup_options.checkers }} \
{% if video_archive_backup_options.buffer_size | default('') != '' %}
  --buffer-size "{{ video_archive_backup_options.buffer_size }}" \
{% endif %}
{% if video_archive_backup_options.use_mmap | default(false) %}
  --use-mmap \
{% endif %}
{% if video_archive_backup_options.ignore_existing | default(true) %}
  --ignore-existing \
{% endif %}
{% if video_archive_backup_options.no_traverse | default(false) %}
  --no-traverse \
{% endif %}
{% if video_archive_backup_options.no_check_dest | default(false) %}
  --no-check-dest \
{% endif %}
  --retries {{ video_archive_backup_options.retries | default(5) }} \
{% if video_archive_backup_options.low_level_retries | default(0) > 0 %}
  --low-level-retries {{ video_archive_backup_options.low_level_retries }} \
{% endif %}
{% if video_archive_backup_options.timeout | default('') != '' %}
  --timeout "{{ video_archive_backup_options.timeout }}" \
{% endif %}
{% if video_archive_backup_options.fast_list | default(true) %}
  --fast-list \
{% endif %}
{% if video_archive_backup_options.use_server_modtime | default(false) %}
  --use-server-modtime \
{% endif %}
{% if video_archive_backup_options.b2_chunk_size | default('') != '' %}
  --b2-chunk-size "{{ video_archive_backup_options.b2_chunk_size }}" \
{% endif %}
{% if video_archive_backup_options.b2_upload_concurrency | default(0) > 0 %}
  --b2-upload-concurrency {{ video_archive_backup_options.b2_upload_concurrency }} \
{% endif %}
{% if video_archive_backup_options.multi_thread_streams | default(0) > 0 %}
  --multi-thread-streams {{ video_archive_backup_options.multi_thread_streams }} \
{% endif %}
{% if video_archive_backup_options.bwlimit | default('') != '' %}
  --bwlimit "{{ video_archive_backup_options.bwlimit }}" \
{% endif %}
{% if video_archive_backup_options.max_transfer | default('') != '' %}
  --max-transfer "{{ video_archive_backup_options.max_transfer }}" \
{% endif %}
{% if video_archive_backup_options.dropbox_batch_mode | default('') != '' %}
  --dropbox-batch-mode "{{ video_archive_backup_options.dropbox_batch_mode }}" \
{% endif %}
{% if video_archive_backup_options.dropbox_batch_size | default(0) > 0 %}
  --dropbox-batch-size {{ video_archive_backup_options.dropbox_batch_size }} \
{% endif %}
{% if video_archive_backup_options.dropbox_batch_timeout | default('') != '' %}
  --dropbox-batch-timeout "{{ video_archive_backup_options.dropbox_batch_timeout }}" \
{% endif %}
  --stats 5m \
  --stats-one-line \
  --progress \
  --log-file "${LOG_FILE}" \
  --log-level {{ video_archive_backup_log_level }}{% if video_archive_backup_dry_run | default(true) %} \
  --dry-run{% endif %}; then
    
    END_TIME=$(date +%s)
    DURATION=$((END_TIME - START_TIME))
    HOURS=$((DURATION / 3600))
    MINUTES=$(((DURATION % 3600) / 60))
    SECONDS=$((DURATION % 60))
    
    log "SUCCESS: ${SOURCE_PATH} -> ${DEST_PATH}"
    log "Duration: ${HOURS}h ${MINUTES}m ${SECONDS}s"
else
    END_TIME=$(date +%s)
    DURATION=$((END_TIME - START_TIME))
    
    log "ERROR: Failed to copy ${SOURCE_PATH} -> ${DEST_PATH}"
    log "Duration: ${DURATION} seconds"
    ERRORS=$((ERRORS + 1))
fi

{% endfor %}

TOTAL_END_TIME=$(date +%s)
TOTAL_DURATION=$((TOTAL_END_TIME - TOTAL_START_TIME))
TOTAL_HOURS=$((TOTAL_DURATION / 3600))
TOTAL_MINUTES=$(((TOTAL_DURATION % 3600) / 60))
TOTAL_SECONDS=$((TOTAL_DURATION % 60))

log "=== Video archive backup completed with ${ERRORS} error(s) ==="
log "Total duration: ${TOTAL_HOURS}h ${TOTAL_MINUTES}m ${TOTAL_SECONDS}s"

if [ ${ERRORS} -gt 0 ]; then
    exit 1
fi

exit 0
