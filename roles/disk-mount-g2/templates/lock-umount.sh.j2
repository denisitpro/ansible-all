#!/bin/bash
# Auto-generated script for LUKS unmount and lock
# Device: {{ item.device }}
# Mount point: {{ item.mount_point | default('/mnt/diskX') }}
## {{ ansible_managed }} ##

set -e

MAPPER_NAME="{{ luks_mapper_name }}"
MAPPER_DEVICE="/dev/mapper/${MAPPER_NAME}"
MOUNT_POINT="{{ item.mount_point | default('/mnt/diskX') }}"

echo "=== LUKS Unmount and Lock Script ==="
echo "Mapper: ${MAPPER_NAME}"
echo "Mount point: ${MOUNT_POINT}"
echo ""

# Confirmation prompt
if [[ "$1" != "-y" && "$1" != "--yes" ]]; then
    read -p "Are you sure you want to unmount and lock? (yes/no): " CONFIRM
    if [[ "${CONFIRM}" != "yes" ]]; then
        echo "[ABORT] Operation cancelled by user"
        exit 1
    fi
fi

# Check if mounted
if mountpoint -q "${MOUNT_POINT}"; then
    # Check what processes are using the mount point
    PROCS_USING=$(lsof +D "${MOUNT_POINT}" 2>/dev/null | tail -n +2 || true)
    if [[ -n "${PROCS_USING}" ]]; then
        echo "[WARNING] Mount point is in use by the following processes:"
        echo ""
        lsof +D "${MOUNT_POINT}" 2>/dev/null || true
        echo ""
        if [[ "$1" != "-f" && "$1" != "--force" ]]; then
            read -p "Force unmount? This may cause data loss! (yes/no): " FORCE_CONFIRM
            if [[ "${FORCE_CONFIRM}" != "yes" ]]; then
                echo "[ABORT] Operation cancelled. Stop the processes first or use --force"
                exit 1
            fi
        fi
        echo "[INFO] Force unmounting ${MOUNT_POINT}..."
        umount -l "${MOUNT_POINT}"
        echo "[OK] Lazy unmounted (will complete when processes release)"
    else
        echo "[INFO] Unmounting ${MOUNT_POINT}..."
        umount "${MOUNT_POINT}"
        echo "[OK] Unmounted"
    fi
else
    echo "[INFO] Not mounted: ${MOUNT_POINT}"
fi

# Check if LUKS is open
if [ -e "${MAPPER_DEVICE}" ]; then
    # Check if device is still in use
    if dmsetup info "${MAPPER_NAME}" 2>/dev/null | grep -q "Open count:.*[1-9]"; then
        echo "[WARNING] LUKS device is still in use"
        if [[ "$1" != "-f" && "$1" != "--force" ]]; then
            read -p "Force close LUKS container? (yes/no): " FORCE_LUKS
            if [[ "${FORCE_LUKS}" != "yes" ]]; then
                echo "[ABORT] LUKS container still open. Wait for unmount to complete or use --force"
                exit 1
            fi
        fi
        echo "[INFO] Waiting for device to be released..."
        sleep 2
    fi
    echo "[INFO] Closing LUKS container..."
    if ! cryptsetup luksClose "${MAPPER_NAME}" 2>/dev/null; then
        echo "[WARNING] Normal close failed, trying deferred close..."
        dmsetup remove --deferred "${MAPPER_NAME}" || true
        echo "[OK] LUKS container marked for deferred removal"
    else
        echo "[OK] LUKS container locked"
    fi
else
    echo "[INFO] LUKS container already closed"
fi

echo ""
echo "=== Done ==="
echo "To unlock and mount again, run: /opt/luks/unlock-mount_{{ luks_mapper_name }}.sh"
