#!/bin/bash
## {{ ansible_managed }} ##
# Auto-generated script for LUKS unlock and mount
# Device: {{ item.device }}
# Mount point: {{ item.mount_point | default('/mnt/diskX') }}

set -e

DEVICE="{{ item.device }}"
MAPPER_NAME="{{ luks_mapper_name }}"
MAPPER_DEVICE="/dev/mapper/${MAPPER_NAME}"
MOUNT_POINT="{{ item.mount_point | default('/mnt/diskX') }}"
FS_TYPE="{{ item.fs | default('ext4') }}"
MOUNT_OPTS="{{ item.opts | default('defaults') }}"

echo "=== LUKS Unlock and Mount Script ==="
echo "Device: ${DEVICE}"
echo "Mapper: ${MAPPER_NAME}"
echo "Mount point: ${MOUNT_POINT}"
echo ""

# Confirmation prompt
if [[ "$1" != "-y" && "$1" != "--yes" ]]; then
    read -p "Are you sure you want to unlock and mount? (yes/no): " CONFIRM
    if [[ "${CONFIRM}" != "yes" ]]; then
        echo "[ABORT] Operation cancelled by user"
        exit 1
    fi
fi

# Check if already unlocked
if [ -e "${MAPPER_DEVICE}" ]; then
    echo "[INFO] LUKS container already unlocked: ${MAPPER_DEVICE}"
else
    echo "[INFO] Unlocking LUKS container..."
    cryptsetup luksOpen "${DEVICE}" "${MAPPER_NAME}"
    echo "[OK] LUKS container unlocked"
fi

# Check if already mounted
if mountpoint -q "${MOUNT_POINT}"; then
    echo "[INFO] Already mounted: ${MOUNT_POINT}"
else
    echo "[INFO] Mounting ${MAPPER_DEVICE} to ${MOUNT_POINT}..."
    mkdir -p "${MOUNT_POINT}"
    mount -t "${FS_TYPE}" -o "${MOUNT_OPTS}" "${MAPPER_DEVICE}" "${MOUNT_POINT}"
    echo "[OK] Mounted successfully"
fi

echo ""
echo "=== Status ==="
df -h "${MOUNT_POINT}"
echo ""
echo "To unmount and lock, run: /opt/luks/lock-umount_{{ luks_mapper_name }}.sh"
