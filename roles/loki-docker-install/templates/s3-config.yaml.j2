{{ ansible_managed | comment }}
# loki s3 config
# Required variables:
#   loki_s3_region - AWS region (e.g., 'us-east-1')
#   loki_s3_bucket_name - S3 bucket name for chunks storage
#   loki_s3_access_key_id - AWS access key ID
#   loki_s3_secret_access_key - AWS secret access key
# Optional variables:
#   loki_s3_endpoint - Custom S3 endpoint (for S3-compatible storage like MinIO)
#   loki_s3_insecure - Use HTTP instead of HTTPS (default: false)
#   loki_s3_s3forcepathstyle - Force path style URLs for S3-compatible storage (default: false)

auth_enabled: false

server:
  http_listen_address: {{loki_http_addr | default('') }}
  http_listen_port: {{loki_http_port | default('3100')}}
  # grpc_listen_port: 9095
  # grpc_listen_address: {{loki_grpc_addr | default('127.0.0.1')}}
{% if loki_ssl is defined %}
  http_tls_config:
    cert_file: {{loki_data_path}}/ssl/{{loki_cert_name | default('fullchain.pem')}}
    key_file: {{loki_data_path}}/ssl/{{loki_key_name | default('privkey.pem')}}
{% endif %}
  http_server_read_timeout: {{loki_http_server_read_timeout | default('120s')}}
  http_server_write_timeout: {{loki_http_server_write_timeout | default('120s')}}
  grpc_server_max_recv_msg_size: {{loki_grpc_server_max_recv_msg_size | default('104857600')}}  # 100 Mb
  grpc_server_max_send_msg_size: {{loki_grpc_server_max_send_msg_size | default('104857600')}}  # 100 Mb
  log_level: {{loki_log_level | default('info')}}

common:
  instance_addr: 127.0.0.1
  path_prefix: /opt/loki
  storage:
    s3:
{% if loki_s3_endpoint is defined and loki_s3_endpoint != '' %}
      endpoint: {{loki_s3_endpoint}}
{% endif %}
      region: {{loki_s3_region | default('eu-central-1')}}
      bucketnames: {{loki_s3_bucket_name | default('loki-bucket-name')}}
      access_key_id: {{loki_s3_access_key_id | default('loki-access-key-id')}}
      secret_access_key: {{loki_s3_secret_access_key | default('loki-secret-access-key')}}
      insecure: {{loki_s3_insecure | default('false')}}
      s3forcepathstyle: {{loki_s3_s3forcepathstyle | default('false')}}
  replication_factor: 1
  ring:
    kvstore:
      store: inmemory

query_range:
  results_cache:
    cache:
      embedded_cache:
        enabled: true
        max_size_mb: {{loki_query_cache_max_size_mb | default('100')}}

schema_config:
  configs:
    - from: {{loki_schema_from_date | default('"2024-04-01"')}}
      object_store: s3
      store: tsdb
      schema: v13
      index:
        prefix: {{loki_index_prefix | default('loki_index_')}}
        period: 24h

ingester:
  chunk_encoding: {{loki_chunk_encoding | default('snappy')}}
  chunk_block_size: {{loki_chunk_block_size | default('262144')}}
  chunk_idle_period: {{loki_chunk_idle_period | default('3m')}}
  chunk_retain_period: {{loki_chunk_retain_period | default('1m')}}
  lifecycler:
    ring:
      kvstore:
        store: inmemory
      replication_factor: 1

limits_config:
  reject_old_samples: {{loki_reject_old_samples | default('true')}}
  reject_old_samples_max_age: {{loki_reject_old_samples_max_age | default('48h')}}
  retention_period: {{loki_retention_period | default('168h')}}
  max_query_lookback: {{loki_max_query_lookback | default(loki_retention_period | default('168h'))}}
  max_entries_limit_per_query: {{loki_max_entries_limit_per_query | default('10000000')}}
  deletion_mode: filter-and-delete
  allow_structured_metadata: {{loki_allow_structured_metadata | default('true')}}
  volume_enabled: {{loki_volume_enabled | default('true')}}

storage_config:
  tsdb_shipper:
    active_index_directory: {{loki_data_path | default('/opt/loki')}}/index
    cache_location: {{loki_data_path | default('/opt/loki')}}/index_cache


compactor:
  working_directory: /opt/loki/compactor
  compaction_interval: {{loki_compaction_interval | default('1h')}}
  retention_enabled: true
  retention_delete_delay: {{loki_retention_delete_delay | default('2h')}}
  retention_delete_worker_count: {{loki_retention_delete_worker_count | default('150')}}
  delete_request_store: s3

ruler:
  alertmanager_url: {{loki_alertmanager_url | default('http://localhost:9093')}}
  # Use Alertmanager v2 API (/api/v2/alerts). This is the default in modern AM deployments.
  enable_alertmanager_v2: true
  storage:
    type: local
    local:
      directory: /opt/loki/rules
  # IMPORTANT: rule_path is a scratch/mapped directory which Loki may wipe on startup.
  # Do NOT point it to the same directory as storage.local.directory (where source rules live),
  # otherwise Loki can delete your rule files.
  rule_path: /opt/loki/rules-tmp
