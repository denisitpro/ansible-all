# {{ ansible_managed }}
# Kora runtime config for Sigma9 wallet — Solana Devnet (LOCAL, gitignored).
# Phase-0 live verification config. Adds a mock 6-dec token we control the mint of
# (4CW8GB…, price-sourced via Mock as a generic mint = 0.001 SOL) so the relayer
# mechanics can be proven end-to-end without the browser-only Circle USDC faucet.
# Real devnet USDC (4zMMC9…) stays allow-listed for the on-device product run.

[kora]
rate_limit = 100

[kora.enabled_methods]
liveness = true
estimate_transaction_fee = true
get_supported_tokens = true
get_payer_signer = true
sign_transaction = true
sign_and_send_transaction = true
transfer_transaction = false
get_blockhash = true
get_config = true

[validation]
max_allowed_lamports = 10000000
max_signatures = 10
price_source = "Mock"
# price_source = "Jupiter"


allow_durable_transactions = false
cross_cluster_check = false


# All 5 base programs + both CCTP v2 IDs are the SAME address on devnet and mainnet-beta,
# so this list is cluster-agnostic (only the token mints below differ per cluster).
allowed_programs = [
    "11111111111111111111111111111111",              # System Program                  (all clusters)
    "TokenkegQfeZyiNwAJbNbGKPFXCWuBvf9Ss623VQ5DA",   # SPL Token Program                (all clusters)
    "ATokenGPvbdGVxr1b2hvZbsiqW5xWH25efTNsLJA8knL",  # Associated Token Account Program (all clusters)
    "ComputeBudget111111111111111111111111111111",   # Compute Budget                   (all clusters)
    "AddressLookupTab1e1111111111111111111111111",   # Address Lookup Table (if used)   (all clusters)
    # CCTP v2 — required for the gasless sol→EVM burn (issue #145). Same IDs devnet + mainnet.
    "CCTPV2vPZJS2u2BBsUoscuikbYjnpFmbFsvVuJdgUMQe",  # CCTP v2 TokenMessengerMinterV2 (depositForBurn)
    "CCTPV2Sm4AdWt5296sk4P66VBZ7bEhcARwFaaS9YPbeC",  # CCTP v2 MessageTransmitterV2  (CPI target of the burn)
]

# Token mints are PER-CLUSTER — pick the set for the cluster this relayer serves:
#   DEVNET  USDC = 4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU  (6 dec)
#   MAINNET USDC = EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v  (6 dec)
allowed_tokens = [
    "4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU",  # DEVNET USDC (swap for mainnet mint in prod)
]

allowed_spl_paid_tokens = [
    "4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU",  # DEVNET USDC (swap for mainnet mint in prod)
]


disallowed_accounts = []

[validation.fee_payer_policy.system]
allow_transfer = true
allow_assign = false
allow_create_account = true
allow_allocate = true

[validation.fee_payer_policy.spl_token]
allow_transfer = true
allow_burn = true # allow burn for gasless
allow_close_account = true
allow_approve = false
allow_revoke = false
allow_set_authority = false
allow_mint_to = false
allow_initialize_mint = false
allow_initialize_account = true
allow_initialize_multisig = false
allow_freeze_account = false
allow_thaw_account = false

# originam
# [validation.price]
# type = "margin"
# margin = 0.05
#
# # kotili
[validation.price]
type = "fixed"
amount = 20000                                          # 0.02 USDC (6 знаков → 0.02 × 10^6)
token = "4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU"  # devnet USDC mint
strict = false

[metrics]
enabled = true
endpoint = "/metrics"
port = 8080
scrape_interval = 60

[metrics.fee_payer_balance]
enabled = true
expiry_seconds = 30
