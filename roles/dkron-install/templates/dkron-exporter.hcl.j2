service {
  name = "{{ consul_dkron_exporter_name }}"
  port = {{ dkron_exporter_port }}
  tags = [
{% for tag in consul_dkron_exporter_tags %}
    "{{ tag }}",
{% endfor %}
  ]

{% if consul_dkron_exporter_token is defined %}
  token = "{{ consul_dkron_exporter_token }}"
{% endif %}

  check = {
    id       = "dkron-exporter-check"
    name     = "Dkron Exporter Health Check"
    tcp      = "localhost:{{ dkron_exporter_port }}"
    interval = "10s"
    timeout  = "1s"
  }
}

