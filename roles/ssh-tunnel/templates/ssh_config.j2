# SSH config for tunnel user {{ ssh_tunnel_user }}
# Generated by Ansible

{% for tunnel in ssh_tunnels %}
{% set remote_host = tunnel.remote_host %}
Host {{ remote_host }}
    HostName {{ remote_host }}
    User {{ ssh_tunnel_user }}
    IdentityFile /home/{{ ssh_tunnel_user }}/.ssh/id_ed25519
    IdentitiesOnly yes
    StrictHostKeyChecking no
    UserKnownHostsFile /dev/null
    LogLevel ERROR
    ServerAliveInterval 30
    ServerAliveCountMax 3
    ConnectTimeout 5
    ConnectionAttempts 3

{% endfor %}
